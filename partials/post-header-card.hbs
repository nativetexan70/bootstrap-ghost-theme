{{!-- Post/page header card — same visual language as post-card-featured.
     Used at the top of post.hbs and page.hbs.
     Context: must be called inside {{#post}} or {{#page}} block.      --}}
<div class="post-header-card card border-0 rounded-3 overflow-hidden shadow-sm mb-0">
    <div class="row g-0">

        {{!-- Left: feature image (hidden when absent) --}}
        {{#if feature_image}}
        <div class="col-lg-5">
            <div class="post-header-card-img bg-subtle h-100">
                <img src="{{img_url feature_image size="l"}}"
                     srcset="{{img_url feature_image size="m"}} 600w,
                             {{img_url feature_image size="l"}} 1000w,
                             {{img_url feature_image size="xl"}} 2000w"
                     sizes="(max-width: 992px) 100vw, 58vw"
                     alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                     class="w-100 h-100 object-fit-cover">
            </div>
        </div>
        {{/if}}

        {{!-- Right (or full-width when no image): meta --}}
        <div class="{{#if feature_image}}col-lg-7{{else}}col-12{{/if}} d-flex">
            <div class="card-body d-flex flex-column p-4 p-lg-5">

                {{!-- Tag eyebrow --}}
                {{#if primary_tag}}
                    <a href="{{primary_tag.url}}"
                       class="text-uppercase small letter-spacing text-accent text-decoration-none mb-3 d-inline-block">
                        {{primary_tag.name}}
                    </a>
                {{else}}
                    {{!-- Page: no tag, just a small label --}}
                    {{#unless tags}}
                        <p class="text-uppercase small letter-spacing text-accent mb-3">Page</p>
                    {{/unless}}
                {{/if}}

                {{!-- Title --}}
                <h1 class="display-5 serif lh-sm mb-3">{{title}}</h1>

                {{!-- Excerpt / custom excerpt --}}
                {{#if custom_excerpt}}
                    <p class="lead text-secondary mb-4 flex-grow-1">{{custom_excerpt}}</p>
                {{else}}
                    {{#if excerpt}}
                        <p class="text-secondary mb-4 flex-grow-1">{{excerpt words="40"}}…</p>
                    {{/if}}
                {{/if}}

                {{!-- Meta row --}}
                <div class="d-flex flex-wrap align-items-center gap-2 small text-muted mt-auto pt-3 border-top">
                    {{#primary_author}}
                        <div class="d-flex align-items-center gap-2">
                            {{#if profile_image}}
                                <img src="{{img_url profile_image size="xs"}}"
                                     alt="{{name}}"
                                     class="rounded-circle flex-shrink-0"
                                     width="26" height="26">
                            {{/if}}
                            <a href="{{url}}" class="text-reset text-decoration-none fw-medium">{{name}}</a>
                        </div>
                        <span aria-hidden="true">·</span>
                    {{/primary_author}}
                    <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
                    {{#if reading_time}}
                        <span aria-hidden="true">·</span>
                        <span>{{reading_time}}</span>
                    {{/if}}
                </div>

                {{!-- Tags pill row --}}
                {{#if tags}}
                    <div class="mt-3 d-flex flex-wrap gap-1">
                        {{#foreach tags}}
                            <a href="{{url}}"
                               class="badge rounded-pill text-bg-light text-decoration-none px-3 py-1 fw-normal">
                                #{{name}}
                            </a>
                        {{/foreach}}
                    </div>
                {{/if}}

            </div>
        </div>

    </div>
</div>
