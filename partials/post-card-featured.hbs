{{!-- Featured / hero post card --}}
<article class="post-card-featured card border-0 rounded-3 overflow-hidden bg-white shadow-sm">
    <div class="row g-0">
        <div class="col-md-5">
            <a href="{{url}}" class="d-block h-100">
                <div class="ratio ratio-16x9 h-100 bg-subtle">
                    {{#if feature_image}}
                        <img src="{{img_url feature_image size="l"}}"
                             alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                             class="w-100 h-100 object-fit-cover">
                    {{else}}
                        <div class="d-flex align-items-center justify-content-center">
                            <span class="brand-mark brand-mark-xl"></span>
                        </div>
                    {{/if}}
                </div>
            </a>
        </div>
        <div class="col-md-7 d-flex">
            <div class="card-body d-flex flex-column p-4 p-lg-5">
                <p class="text-uppercase small letter-spacing text-accent mb-3">
                    <i class="bi bi-star-fill me-1"></i> Featured{{#if primary_tag}} · {{primary_tag.name}}{{/if}}
                </p>

                <h2 class="display-6 serif mb-3 lh-sm"><a href="{{url}}" class="text-reset text-decoration-none stretched-hover">{{title}}</a></h2>

                {{#if excerpt}}
                    <p class="text-secondary mb-4 flex-grow-1">{{excerpt words="35"}}…</p>
                {{/if}}

                <div class="d-flex align-items-center gap-2 small text-muted mt-auto">
                    {{#primary_author}}
                        {{#if profile_image}}
                            <img src="{{img_url profile_image size="xs"}}" alt="{{name}}" class="rounded-circle" width="24" height="24">
                        {{/if}}
                        <span>{{name}}</span>
                    {{/primary_author}}
                    <span>·</span>
                    <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
                    <span>·</span>
                    <span>{{reading_time}}</span>
                </div>
            </div>
        </div>
    </div>
</article>
