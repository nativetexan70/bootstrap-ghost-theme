{{!< default}}

{{#tag}}
<header class="tag-header py-5 border-bottom">
    <div class="container py-4">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <p class="text-uppercase small letter-spacing text-accent mb-3">Tag</p>
                <h1 class="display-4 serif mb-3">{{name}}</h1>
                {{#if description}}
                    <p class="lead text-secondary mb-3">{{description}}</p>
                {{/if}}
                <p class="text-muted small mb-0">{{plural count.posts empty='No posts' singular='% post' plural='% posts'}}</p>
            </div>
        </div>
    </div>
</header>
{{/tag}}

<div class="container py-5">
    <div class="post-feed-grid d-flex flex-column gap-3">
        {{#foreach posts}}
            {{> "post-card"}}
        {{/foreach}}
    </div>
    {{pagination}}
</div>
